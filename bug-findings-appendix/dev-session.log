task: [dev] for hostport in "$LIVE_RELOAD_PROXY_HOST:$LIVE_RELOAD_PROXY_PORT" "$HOST:$PORT"; do
  if nc -z "${hostport%%:*}" "${hostport##*:}" 2>/dev/null; then
    echo "$hostport is already in use — another dev session or orphaned processes?" >&2
    exit 1
  fi
done

task: [dev] task --parallel dev.tailwind dev.web dev.sql dev.go dev.server
task: [dev.go] go tool templ generate \
--log-level=info \
--watch \
--watch-pattern='(.+\.templ$)|(.+_templ\.txt$)|(.*go\.mod$)' \
--path=. \
--proxybind=$LIVE_RELOAD_PROXY_HOST \
--proxyport=$LIVE_RELOAD_PROXY_PORT \
--proxy="http://$HOST:$PORT" \
--open-browser=false \
--cmd='./scripts/dev-run.sh restart'

task: [dev.sql] go tool wgo \
  -debounce=256ms \
  -file=.sql \
  go tool sqlc generate

task: [dev.web] for _ in $(seq 1 100); do
  nc -z "$LIVE_RELOAD_PROXY_HOST" "$LIVE_RELOAD_PROXY_PORT" 2>/dev/null && break
  sleep 0.1
done

task: [dev.tailwind] bunx tailwindcss -i tailwind.css -o static/tailwind.css --watch --minify --cwd .
task: [dev.server] go tool wgo \
  -debounce=512ms \
  -xdir=web/node_modules \
  -xdir=web/static \
  -xdir=bin \
  -xdir=data \
  -file='\.go$' \
  -xfile='_templ\.go$' \
  -file='tmp/restart\.trigger$' \
  ./scripts/dev-run.sh

